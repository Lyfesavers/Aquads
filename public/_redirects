# Serve robots.txt directly (prevent SPA fallback)
/robots.txt /robots.txt 200!

# Handle sitemap with trailing slash - force to prevent SPA fallback
/sitemap.xml/ /.netlify/functions/sitemap 200!

# Serve sitemap via Netlify function (must be first)
/sitemap.xml /.netlify/functions/sitemap 200!

# Legacy blog URL migration: /how-to/ was the previous blog URL prefix before
# we moved to /learn/. The old redirect target (/how-to?blogId=...) no longer
# resolves to any route in the SPA, so any external link still pointing at
# /how-to/{slug}-{id} would 404. Redirect through to /learn?blogId={id} so
# the HowTo.js migration handler can upgrade it to the canonical
# /learn/{slug}-{id} URL. Broad /how-to/* catch-all sends everything else to
# the Learn hub so no legacy URL ends up on a blank SPA page.
/how-to/*-:id /learn?blogId=:id 301!
/how-to/* /learn 301!

# Handle service pages - removed to allow React Router to handle /service/* routes

# Duck Hunt game clean URL
/duck-hunt-game /duck-hunt-game.html 200

# AquaSwap token share URL - ALWAYS prerender
/share/aquaswap /.netlify/functions/prerender-aquaswap 200!

# Game share URL - ALWAYS prerender
/share/game/:id /.netlify/functions/prerender-game-share 200!

# Blog share URL - ALWAYS prerender
/share/blog/:id /.netlify/functions/prerender-blog-share 200!

# Legacy listing landing → keyword URL (must be before SPA fallback)
/why-list /list-token-free 301!

